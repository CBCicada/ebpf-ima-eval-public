#include <linux/bpf.h>

#define SEC(name) __attribute__((section(name), used))

const volatile unsigned char payload[@PAYLOAD_KB@ * 1024] = { 1 };

SEC("socket")
int @PROG_NAME@(struct __sk_buff *skb)
{
    return (skb->len + payload[0] + payload[sizeof(payload) - 1]) & 1;
}

char LICENSE[] SEC("license") = "GPL";
